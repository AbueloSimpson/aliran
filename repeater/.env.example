# Aliran repeater configuration. Copy to .env and edit.
# The repeater needs NO account, NO login and NO keys — only the panel's PUBLIC key.

# REQUIRED: the panel whose catalog names the channels (same key viewers connect to).
PANEL_PUBKEY=

# Channel selection:
#   all                  mirror every channel in the catalog (default)
#   ch1,ch2              mirror these streamIds only
#   category:news        mirror channels whose category matches (comma-list allowed)
# CHANNELS=all

# Live-window retention in seconds. May be DEEPER than the origin's HLS window —
# a regional blip-recovery buffer. Storage per channel ~= bitrate x retention
# (3 Mbit/s x 300 s ~= 110 MB). Default 300.
# RETENTION_SECONDS=300

# Swarm connection budget. A repeater exists to absorb fan-out — default 256.
# Size it to the box's bandwidth: each active viewer costs ~one stream bitrate up.
# SWARM_MAX_PEERS=256

# Swarm UDP socket buffers, in MB (0 = leave that direction alone). This box exists to
# absorb fan-out, so it is the most likely of all to hit a socket-buffer wall — every
# mirrored channel and every viewer share ONE socket pair, and a full buffer is a silent
# kernel packet drop (netstat -su). Defaults are higher here than on the broadcaster.
# Only takes effect if the HOST allows it: setsockopt is silently clamped to
# net.core.{r,w}mem_max (stock Linux ships 212992). Optional helper: deploy/sysctl/
# install.sh — worth running on a repeater specifically, since one on default ceilings
# quietly caps out. Startup logs a warning naming the exact sysctl if it was clamped.
# SWARM_RCVBUF_MB=4
# SWARM_SNDBUF_MB=4

# Where the mirrored (ciphertext) blocks live. In Docker this is pinned to the
# volume; bare-metal defaults to ./data.
# DATA_DIR=./data

# One-line status log per channel every N seconds (0 = off). Default 60.
# STATUS_INTERVAL_SECONDS=60

# Custom DHT bootstrap nodes (host:port, comma-separated). Leave unset for the
# public Hyperswarm DHT.
# BOOTSTRAP=
