# Aliran reseller panel — copy to .env and edit. Every value has a safe default
# except the panel credentials, which you MUST set.

DATA_DIR=./data

# --- The panel admin API this service fronts ---
# Loopback for a single-box deployment (reseller panel on the same host as the
# panel); an https URL for a reseller box on different hardware — in that case
# expose the panel's /api/* ONLY IP-allowlisted to this box (see
# docs/reseller-panel.md). Create a DEDICATED full-privilege panel admin for this
# service and use ITS credentials here (never a human admin's), on the panel host:
#   node src/admin-cli.js add-admin reseller-svc <password>
PANEL_ADMIN_URL=http://127.0.0.1:3210
PANEL_ADMIN_USER=reseller-svc
PANEL_ADMIN_PASS=
PANEL_TIMEOUT_MS=10000

# --- Accounts, pricing, trials ---
# Viewer account names are plain panel usernames (first come, first served —
# a clash with an existing panel user surfaces as the panel's own error).
# 1 credit = 1 month = this many days, flat. maxDevices is a per-account setting
# within each reseller's limit, not priced.
DAYS_PER_MONTH=31
TRIAL_HOURS=24
TRIAL_DAILY_CAP_DEFAULT=3
MAX_DEVICES_LIMIT_DEFAULT=3

# --- The subscription clock ---
# The panel has NO account expiry, so this sweep is the only thing that ends a
# lapsed subscription (it disables lapsed accounts on the panel). It backs off to
# 15 min while the panel is unreachable; the work list re-derives each tick.
SWEEP_INTERVAL_SEC=300
# Reconcile diffs the panel against local records. Repairs apply only with
# RECONCILE_REPAIR=1; otherwise divergences are reported (state/reconcile.json)
# but not changed. 0 = report-only.
RECONCILE_INTERVAL_SEC=3600
RECONCILE_REPAIR=0

# --- Control dashboard + API ---
# Loopback by default; bind 0.0.0.0 ONLY behind a TLS reverse proxy. This dashboard
# is meant for third parties — see deploy/Caddyfile.example (the IP-allowlist note).
CONTROL_HOST=127.0.0.1
CONTROL_PORT=3330
CONTROL_SESSION_TTL_HOURS=12
LOCKOUT_THRESHOLD=10
LOCKOUT_SECONDS=900

# Argon2id cost for principal passwords (interactive-grade defaults).
ARGON2_MEM_KIB=65536
ARGON2_TIME=2
