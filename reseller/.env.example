# Aliran reseller panel — copy to .env and edit. Every value has a safe default
# except the panel credentials, which you MUST set.

DATA_DIR=./data

# --- The panel admin API this service fronts ---
# Loopback for a single-box deployment (reseller panel on the same host as the
# panel); an https URL for a reseller box on different hardware — in that case
# expose the panel's /api/* ONLY IP-allowlisted to this box (see
# docs/reseller-panel.md). Create a DEDICATED full-privilege panel admin for this
# service and use ITS credentials here (never a human admin's), on the panel host:
#   node src/admin-cli.js add-admin reseller-svc <password>
PANEL_ADMIN_URL=http://127.0.0.1:3210
PANEL_ADMIN_USER=reseller-svc
PANEL_ADMIN_PASS=
PANEL_TIMEOUT_MS=10000

# --- Accounts, pricing, trials ---
# Viewer account names are plain panel usernames (first come, first served —
# a clash with an existing panel user surfaces as the panel's own error).
# 1 credit = 1 month = this many days, flat. Devices are not priced: the device
# count is an ADMIN-SET POLICY inherited down the hierarchy — accounts receive
# their creator's effective value; MAX_DEVICES_LIMIT_DEFAULT is the root
# fallback when no admin has set an explicit value anywhere on the chain.
DAYS_PER_MONTH=31
TRIAL_HOURS=24
TRIAL_DAILY_CAP_DEFAULT=3
MAX_DEVICES_LIMIT_DEFAULT=3

# --- The subscription clock ---
# The panel has NO account expiry, so this sweep is the only thing that ends a
# lapsed subscription (it disables lapsed accounts on the panel). It backs off to
# 15 min while the panel is unreachable; the work list re-derives each tick.
SWEEP_INTERVAL_SEC=300
# Reconcile diffs the panel against local records. Repairs apply only with
# RECONCILE_REPAIR=1; otherwise divergences are reported (state/reconcile.json)
# but not changed. 0 = report-only.
RECONCILE_INTERVAL_SEC=3600
RECONCILE_REPAIR=0

# --- Control dashboard + API ---
# Loopback by default; bind 0.0.0.0 ONLY behind a TLS reverse proxy. This dashboard
# is meant for third parties — see deploy/Caddyfile.example (the IP-allowlist note),
# or deploy/cloudflared.compose.example.yml to publish it through a Cloudflare
# Tunnel when the box has no public IP / open port.
CONTROL_HOST=127.0.0.1
CONTROL_PORT=3330
CONTROL_SESSION_TTL_HOURS=12
LOCKOUT_THRESHOLD=10
LOCKOUT_SECONDS=900
# Behind a trusted proxy/tunnel, name the header carrying the real client IP so
# the login lockout keys on the client, not the proxy's shared address:
#   Cloudflare Tunnel:  TRUST_PROXY_HEADER=cf-connecting-ip
#   Caddy / nginx:      TRUST_PROXY_HEADER=x-forwarded-for
# Set ONLY when the port is reachable exclusively through that proxy — a directly
# reachable port lets clients spoof the header. Empty = key on the socket address.
# (deploy/cloudflared.compose.example.yml presets this AND publishes no host port,
# which satisfies that rule by construction; there, PANEL_ADMIN_URL becomes
# http://host.docker.internal:3210 for the single-box topology.)
TRUST_PROXY_HEADER=
# Cloudflare Tunnel token (only with deploy/cloudflared.compose.example.yml —
# cloudflared reads this; the reseller service ignores it).
#TUNNEL_TOKEN=

# --- White-label ---
# Rebrand without touching source (full manual: docs/white-label.md → "Reseller
# panel dashboard"). Name shows in the login card, sidebar and page title; the
# logo (SVG preferred, or PNG at 2× — rendered ≤30px tall in the sidebar, ≤44px
# on login, transparent background) replaces the brand text; the favicon is
# 32×32 PNG/ICO or SVG; the theme file (JSON) overrides any of the 11 shared
# theme tokens with 6-digit hex, e.g. {"accent":"#F59E0B","accent-dim":"#B45309"}
# — served as /branding.css on top of the stock stylesheet.
#BRAND_NAME=Acme TV
#BRAND_LOGO_FILE=./brand-logo.svg
#BRAND_FAVICON_FILE=./brand-favicon.png
#BRAND_THEME_FILE=./brand-theme.json

# --- Automated credit top-ups (payment webhook) ---
# Setting a secret enables POST /api/webhooks/credits: HMAC-SHA256-signed
# ("<ts>.<raw body>" with x-topup-timestamp/-signature headers, ±300 s window),
# idempotent by event id, mints a normal MINT ledger line (actor "webhook").
# Use a LONG random value (32+ chars) — it is the only thing authenticating a
# mint. Unset = the route answers 404. See docs/reseller-panel.md.
#WEBHOOK_SECRET=

# Argon2id cost for principal passwords (interactive-grade defaults).
ARGON2_MEM_KIB=65536
ARGON2_TIME=2
