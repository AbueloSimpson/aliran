# Aliran library configuration (copy to .env and edit).
# The library is a STANDALONE service — run it on whatever box has the disk and the
# spare CPU for ingest bursts; it does not need to share hardware with the live fleet.

# Where titles live: registry (titles.json), secrets/ (per-title encryption keys,
# admin accounts) and store/ (the encrypted per-title drives). In Docker this is the
# /data volume. Disk usage = the sum of title sizes (a title keeps ALL its segments);
# it is reclaimed only by deleting the title.
DATA_DIR=./data

# The panel to register titles with (same key viewers use). From `admin-cli init`.
PANEL_PUBKEY=

# Enrolled publisher identity (S26) — the library should ALWAYS run as its own named
# publisher, scoped to its title ids, never sharing the live fleet's key:
#   panel:  node src/admin-cli.js add-publisher library1 --scopes 'vod-*'
# add-publisher prints the matching PUBLISHER_KEY once. Title ids must match the scopes.
PUBLISHER_NAME=
PUBLISHER_KEY=

# VOD HLS segment length (seconds). Shorter = finer seek granularity + demand-paging,
# more per-request overhead. Per-title override in the control API (`hlsTime`).
#HLS_TIME=4

# How many ingest jobs run at once. A `-c copy` remux is cheap; a transcode eats
# 0.5-1 CPU core for the length of the burst — the default runs strictly one at a
# time and queues the rest. Raise only on a box with spare cores.
#INGEST_CONCURRENCY=1

# Swarm connection budget. A library exists to absorb viewer fan-out, so the default
# is high (256) — ONE swarm carries every title on this box.
#SWARM_MAX_PEERS=256

# Swarm UDP socket buffers, in MB (0 = leave that direction at the OS/udx default).
# A seeder is SEND-dominant, so both default to 4 like the repeater's. The host must
# allow it via net.core.{r,w}mem_max (deploy/sysctl/) or the kernel silently clamps —
# a startup warning names the exact sysctl. See docs/kb/network-tuning.md.
#SWARM_RCVBUF_MB=4
#SWARM_SNDBUF_MB=4

# Control API + minimal dashboard (the only way to add titles). Create an admin first:
#   node src/library-cli.js add-admin <name>
# Binds loopback by default — expose it only behind TLS (see deploy/Caddyfile.example).
CONTROL_ENABLED=1
#CONTROL_HOST=127.0.0.1
#CONTROL_PORT=3320
#CONTROL_SESSION_TTL_HOURS=12

# Login lockout + Argon2id cost for control-admin passwords (same knobs as the
# broadcaster's control API).
#LOCKOUT_THRESHOLD=10
#LOCKOUT_SECONDS=900
#ARGON2_MEM_KIB=65536
#ARGON2_TIME=2

# Custom DHT bootstrap nodes (local testnets). Omit for the public DHT.
#BOOTSTRAP=
