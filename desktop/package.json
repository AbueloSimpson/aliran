{
  "name": "aliran-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Aliran desktop player for Windows — Electron shell over @aliran/player-sdk (never published; built with electron-builder)",
  "license": "MIT",
  "type": "module",
  "main": "main/index.js",
  "scripts": {
    "build": "node build.mjs",
    "typecheck": "tsc --noEmit",
    "start": "npm run build && electron .",
    "dist": "npm run build && electron-builder --win nsis portable"
  },
  "dependencies": {
    "@aliran/player-sdk": "^0.1.1",
    "hls.js": "^1.6.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "electron": "^37.2.0",
    "electron-builder": "^26.0.12",
    "esbuild": "^0.25.0",
    "typescript": "^5.6.0"
  }
}
