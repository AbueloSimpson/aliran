{
  "name": "aliran",
  "version": "0.0.1",
  "private": true,
  "description": "Self-hostable peer-to-peer OTT streaming platform on the Holepunch/Pear stack",
  "license": "MIT",
  "workspaces": [
    "core",
    "panel",
    "broadcaster",
    "tools"
  ],
  "dependencies": {
    "@aliran/bare-node-crypto": "file:client/backend/shims/bare-node-crypto"
  },
  "scripts": {
    "panel": "npm --workspace panel start",
    "broadcaster": "npm --workspace broadcaster start",
    "viewer": "npm --workspace tools run viewer --",
    "test": "npm run test:core",
    "test:core": "node core/test.mjs",
    "test:stream": "node tools/e2e-stream-test.mjs",
    "test:login": "node tools/e2e-login-test.mjs",
    "test:session": "node tools/e2e-session-test.mjs",
    "test:register": "node tools/e2e-register-test.mjs",
    "test:assets": "node tools/e2e-assets-test.mjs"
  },
  "keywords": [
    "p2p",
    "streaming",
    "ott",
    "holepunch",
    "pear",
    "hyperswarm",
    "hyperdrive",
    "webrtc-alternative"
  ],
  "engines": {
    "node": ">=20"
  },
  "comment": "client/ is a separate React Native (react-native-tvos) project and is intentionally NOT an npm workspace here — it has its own toolchain. See client/README.md."
}
