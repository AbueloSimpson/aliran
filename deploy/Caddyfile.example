# TLS for the two Aliran dashboards with Caddy (automatic HTTPS via Let's Encrypt).
#
# The admin (panel, :3210) and control (broadcaster, :3310) APIs speak plain HTTP and
# bind 127.0.0.1 by default — NEVER expose them raw. Point DNS A-records at the box,
# install Caddy (https://caddyserver.com/docs/install), drop this file at
# /etc/caddy/Caddyfile with your domains, and `sudo systemctl reload caddy`.
#
# Full walkthrough (DNS, cert, credentials, firewall): docs/kb/public-dashboards.md
#
# No domain? Skip Caddy entirely and use an SSH tunnel from your workstation:
#   ssh -N -L 3210:127.0.0.1:3210 -L 3310:127.0.0.1:3310 user@your-vps
# then browse http://127.0.0.1:3210 (panel) and http://127.0.0.1:3310 (broadcaster).
#
# Certificates are automatic (Let's Encrypt). In production, issuance completed via
# the tls-alpn-01 challenge on port 443 with no extra configuration. A freshly
# started Caddy races its own ACME flow for a few seconds — a first curl returning
# 000 right after `systemctl start caddy` is the exchange still in flight, not a
# failure. Retry a few seconds later.
#
# ---------------------------------------------------------------------------------
# ⚠ basic_auth MUST NOT cover /api/* — HTTP has ONE Authorization header
# ---------------------------------------------------------------------------------
# Both dashboards authenticate to their own API with `Authorization: Bearer <token>`.
# If basic_auth also guards /api/*, the browser's automatic `Authorization: Basic …`
# is REPLACED by that Bearer header on every API call. Caddy then sees a non-Basic
# value, rejects it, and answers 401 + `WWW-Authenticate: Basic` — which makes the
# browser re-prompt for a password on every single request. The symptom is a login
# popup that will not go away.
#
# The `@ui not path /api/*` matcher below is what prevents that. Do not remove it.
#
# Be honest about what this buys: the UI gets two gates, the API gets ONE — its own
# rate-limited token login, reachable without basic auth. That keeps casual scanners
# off the dashboard; it does not harden the API. If you want a real second layer on
# the API, use something that does not touch the Authorization header — an IP
# allowlist (see the commented block) or mTLS.
#
# (`basic_auth` is the Caddy >= 2.8 spelling of the directive; older packaged builds
# call it `basicauth` — same syntax otherwise.)

# The broadcaster control dashboard (:3310) — publish this one first: it is the
# smaller surface (starts/stops channels, but cannot create users or grants).
studio.example.com {
	@ui not path /api/*
	basic_auth @ui {
		# caddy hash-password --plaintext 'your-password'   (bcrypt, cost 14 — the default)
		operator $2a$14$REPLACE_WITH_YOUR_OWN_BCRYPT_HASH
	}
	reverse_proxy 127.0.0.1:3310
}

# The panel admin dashboard (:3210) takes exactly the same shape — but exposing it
# is a BIGGER decision: its API can create users and grant channels. Leaving it
# loopback-only behind the SSH tunnel is a fine permanent answer. If you do publish
# it, give it its OWN password — do not reuse the broadcaster's hash.
panel.example.com {
	@ui not path /api/*
	basic_auth @ui {
		operator $2a$14$A_DIFFERENT_HASH_FOR_THE_PANEL
	}
	reverse_proxy 127.0.0.1:3210
}

# The reseller panel (:3330) — same shape, but it is MEANT to be used by third
# parties, so the recommendation flips: an IP allowlist is the real second gate
# (basic_auth still can't cover /api/*, so it only slows a browser reaching the
# dashboard HTML). If your resellers come from known networks, allowlist them and
# skip basic_auth entirely; otherwise keep basic_auth on the UI AND put the panel
# admin API it calls behind an allowlist restricted to THIS box (below).
reseller.example.com {
	@allowed remote_ip 203.0.113.0/24
	handle @allowed {
		@ui not path /api/*
		basic_auth @ui {
			operator $2a$14$YET_ANOTHER_HASH_FOR_THE_RESELLER
		}
		reverse_proxy 127.0.0.1:3330
	}
	respond 403
}

# Two-box reseller topology: if the reseller panel runs on a DIFFERENT machine, its
# PANEL_ADMIN_URL points here, so the panel admin API must be reachable from it —
# publish it, but ONLY to the reseller box's IP (it is the sole client). This is the
# one place the panel's /api/* is deliberately exposed, and the allowlist is what
# makes that safe (it inspects the connection, not the Bearer header).
#
# panel-api.example.com {
# 	@reseller_box remote_ip 198.51.100.7
# 	handle @reseller_box {
# 		reverse_proxy 127.0.0.1:3210
# 	}
# 	respond 403
# }
#
# Stronger alternative for ANY dashboard — an IP allowlist composes with the app's
# Bearer auth because it inspects the connection, not the Authorization header.
# Protects /api/* too.
#
# studio.example.com {
# 	@allowed remote_ip 203.0.113.4 198.51.100.0/24
# 	handle @allowed {
# 		reverse_proxy 127.0.0.1:3310
# 	}
# 	respond 403
# }
