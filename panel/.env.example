# Aliran panel configuration — copy to .env and edit. NEVER commit .env.

# Storage (Corestore + keys). Gitignored. Back this up securely.
DATA_DIR=./data

# Route via DHT relays so peers can't see the origin IP (default off).
RELAY_ONLY=false

# Argon2id cost (tune to target client hardware; higher = safer, slower login).
ARGON2_MEM_KIB=262144
ARGON2_TIME=3

# Accounts / sessions
MAX_DEVICES_DEFAULT=2
SESSION_TTL_DAYS=30

# Brute-force controls
POW_DIFFICULTY=16
LOCKOUT_THRESHOLD=10
LOCKOUT_SECONDS=900

# Accept UNNAMED broadcaster registrations signed with the shared legacy publisher
# key from `admin-cli init`. Once every broadcaster site is enrolled with its own
# key + channel scopes (`admin-cli add-publisher`, PUBLISHER_NAME in its .env),
# set 0 so only enrolled identities can register.
LEGACY_PUBLISHER=1

# Admin HTTP API (dashboard/control plane). Off by default. Create an admin first:
#   node src/admin-cli.js add-admin <name>
# Bind loopback unless you have TLS in front (the API speaks plain HTTP).
ADMIN_ENABLED=false
ADMIN_HOST=127.0.0.1
ADMIN_PORT=3210
ADMIN_SESSION_TTL_HOURS=12

# Optional: custom DHT bootstrap nodes (comma-separated host:port). Empty = public DHT.
BOOTSTRAP=

# Swarm UDP socket buffers, in MB (0 = leave that direction alone). Every client
# replicates the catalog over the panel's single swarm, so its socket pair carries the
# whole lineup's fan-out. A full UDP buffer is a silent kernel packet drop (netstat -su).
# Only takes effect if the HOST allows it: setsockopt is silently clamped to
# net.core.{r,w}mem_max, which ships at 212992 on stock Linux. Optional helper to raise it:
# deploy/sysctl/install.sh. The panel logs a warning naming the exact sysctl if its
# request was capped. Defaults: 2/2.
# SWARM_RCVBUF_MB=2
# SWARM_SNDBUF_MB=2
