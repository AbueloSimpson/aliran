<?xml version="1.0" encoding="utf-8"?>
<!-- The Bare worklet serves feeds and catalog art on loopback over plain HTTP
     (http://127.0.0.1:<port>/...), which Android blocks by default since API 28.
     Permit cleartext ONLY to loopback (plus the emulator's host aliases, used by
     Metro in dev builds); all other traffic keeps the platform HTTPS-only default. -->
<network-security-config>
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">127.0.0.1</domain>
        <domain includeSubdomains="false">localhost</domain>
        <domain includeSubdomains="false">10.0.2.2</domain>
        <domain includeSubdomains="false">10.0.3.2</domain>
    </domain-config>
</network-security-config>
