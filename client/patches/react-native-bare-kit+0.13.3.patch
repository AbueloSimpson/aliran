+typedef struct bare_api_s {
+  int (*worklet_alloc)(bare_worklet_t **);
+  int (*worklet_init)(bare_worklet_t *, const bare_worklet_options_t *);
+  void (*worklet_destroy)(bare_worklet_t *);
+  void *(*worklet_get_data)(bare_worklet_t *);
+  void (*worklet_set_data)(bare_worklet_t *, void *);
+  int (*worklet_start)(bare_worklet_t *, const char *, const uv_buf_t *, int, const char *[]);
+  int (*worklet_suspend)(bare_worklet_t *, int);
