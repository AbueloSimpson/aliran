+#define bare_ipc_poll_init bare_api()->ipc_poll_init
+#define bare_ipc_poll_destroy bare_api()->ipc_poll_destroy
+#define bare_ipc_poll_get_data bare_api()->ipc_poll_get_data
+#define bare_ipc_poll_set_data bare_api()->ipc_poll_set_data
+#define bare_ipc_poll_start bare_api()->ipc_poll_start
+#define bare_ipc_poll_stop bare_api()->ipc_poll_stop
+
+#endif // __ANDROID__
