+  table.field = reinterpret_cast<decltype(table.field)>(dlsym(handle, symbol)); \
+  if (table.field == nullptr) return nullptr;
+
+    BARE_API_LOAD(worklet_alloc, "bare_worklet_alloc")
+    BARE_API_LOAD(worklet_init, "bare_worklet_init")
+    BARE_API_LOAD(worklet_destroy, "bare_worklet_destroy")
+    BARE_API_LOAD(worklet_get_data, "bare_worklet_get_data")
+    BARE_API_LOAD(worklet_set_data, "bare_worklet_set_data")
+    BARE_API_LOAD(worklet_start, "bare_worklet_start")
+    BARE_API_LOAD(worklet_suspend, "bare_worklet_suspend")
+    BARE_API_LOAD(worklet_resume, "bare_worklet_resume")
+    BARE_API_LOAD(worklet_wakeup, "bare_worklet_wakeup")
+    BARE_API_LOAD(worklet_terminate, "bare_worklet_terminate")
+    BARE_API_LOAD(ipc_alloc, "bare_ipc_alloc")
+    BARE_API_LOAD(ipc_init, "bare_ipc_init")
+    BARE_API_LOAD(ipc_destroy, "bare_ipc_destroy")
+    BARE_API_LOAD(ipc_read, "bare_ipc_read")
+    BARE_API_LOAD(ipc_write, "bare_ipc_write")
+    BARE_API_LOAD(ipc_poll_alloc, "bare_ipc_poll_alloc")
+    BARE_API_LOAD(ipc_poll_init, "bare_ipc_poll_init")
+    BARE_API_LOAD(ipc_poll_destroy, "bare_ipc_poll_destroy")
+    BARE_API_LOAD(ipc_poll_get_data, "bare_ipc_poll_get_data")
+    BARE_API_LOAD(ipc_poll_set_data, "bare_ipc_poll_set_data")
+    BARE_API_LOAD(ipc_poll_start, "bare_ipc_poll_start")
+    BARE_API_LOAD(ipc_poll_stop, "bare_ipc_poll_stop")
+
+#undef BARE_API_LOAD
+
+    return &table;
+  }();
+
+  return api;
