+  int (*ipc_init)(bare_ipc_t *, bare_worklet_t *);
+  void (*ipc_destroy)(bare_ipc_t *);
+  int (*ipc_read)(bare_ipc_t *, void **, size_t *);
+  int (*ipc_write)(bare_ipc_t *, const void *, size_t);
+  int (*ipc_poll_alloc)(bare_ipc_poll_t **);
+  int (*ipc_poll_init)(bare_ipc_poll_t *, bare_ipc_t *);
+  void (*ipc_poll_destroy)(bare_ipc_poll_t *);
+  void *(*ipc_poll_get_data)(bare_ipc_poll_t *);
+  void (*ipc_poll_set_data)(bare_ipc_poll_t *, void *);
+  int (*ipc_poll_start)(bare_ipc_poll_t *, int, bare_ipc_poll_cb);
+  int (*ipc_poll_stop)(bare_ipc_poll_t *);
+} bare_api_s;
+}
+
+static bare_api_s *
+bare_api() {
+  static bare_api_s *api = []() -> bare_api_s * {
+    if (android_get_device_api_level() < 29) return nullptr;
+
+    // RTLD_GLOBAL: the runtime's addons resolve bare symbols from the global scope,
+    // exactly as they did when libbare-kit.so loaded as a DT_NEEDED of the app.
+    void *handle = dlopen("libbare-kit.so", RTLD_NOW | RTLD_GLOBAL);
+
+    if (handle == nullptr) return nullptr;
+
