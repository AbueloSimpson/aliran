# Aliran broadcaster configuration — copy to .env and edit. NEVER commit .env.

# Storage (Corestore + the feed Hyperdrive key). Gitignored.
DATA_DIR=./data

# The panel to register this stream with (hex public key from `panel admin-cli init`).
PANEL_PUBKEY=

# Publisher key (secret) printed by `panel admin-cli init` — authorizes registration.
PUBLISHER_KEY=

# Catalog id + display metadata for this stream.
STREAM_ID=default
TITLE=
CATEGORY=

# Input source:
#   rtmp                       -> run an RTMP listener for OBS to push to
#                                 (push URL + stream key are printed at startup)
#   rtsp://host/...            -> pull from an RTSP source
#   http://host/playlist.m3u8  -> pull from an existing HLS source
#   /path/to/file.mp4          -> loop a local file (testing)
# SRT/UDP push listeners and per-channel transcode settings are configured per
# channel over the control API (typed `input` objects; see docs/reference.md).
INPUT=rtmp
RTMP_PORT=1935

# Shown in operator-facing push URLs (rtmp://<PUBLIC_HOST>:<port>/live/<key>).
# Display-only; listeners always bind 0.0.0.0. Defaults to the machine's address.
PUBLIC_HOST=

# Port range for auto-allocated push-ingest listeners (channels created without
# an explicit port). Remember to open these on the firewall for your encoder.
INGEST_PORT_BASE=5000
INGEST_PORT_MAX=5999

# GPU transcode: VAAPI render node used by the h264_vaapi encoder (Linux).
VAAPI_DEVICE=/dev/dri/renderD128

# Live HLS windowing. Short segments cut time-to-first-frame; 8 keeps a real
# shareable window for P2P re-seeding. Deepen HLS_LIST_SIZE (12–16) for large swarms.
HLS_TIME=2
HLS_LIST_SIZE=8

# Recycle a channel's RUNNING ffmpeg once its memory (VmRSS+VmSwap) crosses this cap
# (MB). Long-running live-HLS pulls slowly accumulate demuxer state on some upstreams
# (SSAI ad insertion) that only a process restart returns; the watchdog treats the cap
# like a stalled edge — same backoff, no feed rotation, sub-window viewer blip. A fresh
# pull ffmpeg runs ~13–30 MB RSS, so 150 is generous headroom. 0 disables. Linux-only.
FFMPEG_MAX_RSS_MB=150

# Feed buffer mode — see docs/kb/feed-buffer.md.
#   disk (default) = persistent feed identity: feedKey/DHT topic STABLE across
#                    restarts, so returning viewers rejoin a warm topic and resume
#                    their replica (faster time-to-play, healthier P2P). Storage stays
#                    window-bounded via the rolling reclaim (tens of MB, not byte-flat).
#   ram            = ephemeral session feeds: fresh feedKey per start, segment data
#                    only ever in memory. Keeps the host disk byte-flat, but every
#                    restart costs viewers a fresh DHT discovery.
FEED_BUFFER=disk

# Optional per-channel swarm connection budget. Every channel runs its OWN swarm, so
# this caps EACH channel's fan-out separately (hyperswarm's default of 64 is also per
# channel). Connections beyond the budget are dropped at accept time. Leave headroom
# for non-viewer peers (repeaters, the panel's blobsKey probe) — they take a slot
# like any viewer.
# SWARM_MAX_PEERS=64

# ffmpeg live-window scratch dir. Default = OS temp (disk-backed in a container). At high
# channel density the constant per-segment write churn is IOPS-bound, not space-bound — point
# this at a tmpfs (RAM) so it never hits disk. The "scale profile" is HLS_WORK_DIR on tmpfs +
# FEED_BUFFER=ram (segments AND the feed in RAM = zero disk IOPS). See docs/kb/scaling.md.
# HLS_WORK_DIR=/hlstmp

# self = encrypted Hyperdrive (default) | drm = CENC via a multi-DRM packager
PROTECTION=self

# Control HTTP API (multi-channel management + the S12b web UI). Off by default.
# Create an admin first: node src/control-cli.js add-admin <name>
# Bind loopback unless you have TLS in front (the API speaks plain HTTP).
CONTROL_ENABLED=false
CONTROL_HOST=127.0.0.1
CONTROL_PORT=3310
CONTROL_SESSION_TTL_HOURS=12

# Control-API login lockout + Argon2id cost for admin passwords.
LOCKOUT_THRESHOLD=10
LOCKOUT_SECONDS=900
ARGON2_MEM_KIB=65536
ARGON2_TIME=2

# Optional custom DHT bootstrap (comma-separated host:port). Empty = public DHT.
BOOTSTRAP=
